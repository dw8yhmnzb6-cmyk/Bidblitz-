{
  "appId": "com.bidblitz.app",
  "appName": "BidBlitz",
  "webDir": "build",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#1e293b",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#1e293b"
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "allowsLinkPreview": true,
    "backgroundColor": "#1e293b"
  },
  "android": {
    "backgroundColor": "#1e293b",
    "allowMixedContent": true
  }
}
